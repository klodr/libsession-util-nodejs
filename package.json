{
  "main": "index.js",
  "name": "@klodr/libsession-util-nodejs",
  "packageManager": "pnpm@10.28.1",
  "description": "Node.js bindings for libsession-util — klodr fork targeting Node 22 runtime (vs upstream Electron 40)",
  "version": "0.6.21",
  "files": [
    "index.js",
    "index.d.ts",
    "src/**",
    "include/**",
    "types/**",
    "scripts/**",
    "libsession-util/cmake/**",
    "libsession-util/CMakeLists.txt",
    "libsession-util/include/**",
    "libsession-util/src/**",
    "libsession-util/proto/**",
    "libsession-util/external/**",
    "libsession-util/LICENSE*",
    "CMakeLists.txt",
    "BUILDING.md",
    "README.md",
    "LICENSE*"
  ],
  "license": "GPL-3.0",
  "author": {
    "name": "Oxen Project",
    "email": "team@oxen.io"
  },
  "contributors": [
    {
      "name": "Claude Perrin",
      "email": "klodr@users.noreply.github.com",
      "url": "https://github.com/klodr"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klodr/libsession-util-nodejs.git"
  },
  "scripts": {
    "clean": "rimraf .cache build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cpp": "cmake-js build --runtime=node --runtime-version=22.22.2 --CDSUBMODULE_CHECK=OFF --CDLOCAL_MIRROR=https://oxen.rocks/deps --CDENABLE_NETWORKING=OFF --CDWITH_TESTS=ON --target testAll && ./build/libsession-util/tests/testAll",
    "lint:cpp": "cppcheck --std=c++20 -j8  src",
    "lint": "find src include -name '*.cpp' -o -name '*.hpp' | xargs clang-format-19 -i",
    "install": "node scripts/install-from-prebuild.mjs",
    "install:from-source": "cmake-js build --runtime=node --runtime-version=22.22.2 --CDSUBMODULE_CHECK=OFF --CDLOCAL_MIRROR=https://oxen.rocks/deps --CDENABLE_NETWORKING=OFF --CDWITH_TESTS=OFF",
    "prepare_release": "sh prepare_release.sh",
    "dedup": "pnpm dedupe --check"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "clang-format": "^1.8.0",
    "rimraf": "2.6.2",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "cmake-js": "8.0.0",
    "node-addon-api": "^8.3.1"
  },
  "engines": {
    "node": ">=22.22.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "typings": "index.d.ts"
}
